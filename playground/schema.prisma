datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

generator modelcore {
  provider = "node ../dist/generator.js"
  output   = "./src/models/generated"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  age   Int?
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
}
